# Docker Compose PostgreSQL initialization values.
# These are applied only when the PostgreSQL data volume is created for the first time.
POSTGRES_DB=assistops
POSTGRES_USER=assistops
POSTGRES_PASSWORD=assistops

# Spring Boot datasource values and the PostgreSQL host port exposed by Docker Compose.
DB_HOST=localhost
DB_PORT=15432
DB_NAME=assistops
DB_USERNAME=assistops
DB_PASSWORD=assistops

# Docker Compose MinIO root credentials.
MINIO_ROOT_USER=assistops
MINIO_ROOT_PASSWORD=assistops123

# Spring Boot MinIO client values.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=assistops
MINIO_SECRET_KEY=assistops123
MINIO_BUCKET=assistops-documents
MINIO_REGION=us-east-1

OLLAMA_BASE_URL=http://localhost:11434

REDIS_HOST=localhost
REDIS_PORT=6379

# 개발용 JWT 예시값입니다. 로컬 외 환경에서는 git 밖의 실제 secret으로 override하세요.
JWT_SECRET=dev-only-local-secret-change-me-this-string-is-for-local-development-only
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=60
