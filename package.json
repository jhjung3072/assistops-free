{
  "name": "ai-knowledge-hub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "lint:web": "pnpm --dir apps/web lint",
    "dev:api": "cd apps/api && ./gradlew bootRun",
    "test:api": "cd apps/api && ./gradlew test",
    "build:api": "cd apps/api && ./gradlew build",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d",
    "infra:logs": "docker compose logs -f",
    "infra:ps": "docker compose ps"
  }
}
